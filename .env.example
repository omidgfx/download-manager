# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: The port the app runs on (must be 3000 in AI Studio)
PORT=3000

# DATABASE_URL: Local PostgreSQL or Termux PostgreSQL database url
DATABASE_URL="postgresql://postgres:2@localhost:5432/download_manager"

# DOWNLOAD_DIR: Directory where downloaded parts and finished files are saved
DOWNLOAD_DIR="./downloads"

# MAX_CONCURRENT_TASKS: Limits number of downloads running simultaneously
MAX_CONCURRENT_TASKS=3