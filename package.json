    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-schedule": "^2.1.1",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.1",
    "vite": "^6.2.3"
